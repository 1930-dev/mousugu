// App-Common.xcconfig — settings shared by both app targets.
// Channel-specific differences live in App-Direct.xcconfig (DMG, ships Sparkle)
// and App-MAS.xcconfig (Mac App Store, no updater).
//
// PRODUCT_NAME is spelled out rather than $(TARGET_NAME): both channels ship
// the same user-facing app, so both targets must produce MouSugu.app.

ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME = AccentColor
CODE_SIGN_STYLE = Automatic
CURRENT_PROJECT_VERSION = 11
ENABLE_APP_SANDBOX = YES
ENABLE_HARDENED_RUNTIME = YES
ENABLE_INCOMING_NETWORK_CONNECTIONS = NO
ENABLE_PREVIEWS = YES
ENABLE_RESOURCE_ACCESS_AUDIO_INPUT = NO
ENABLE_RESOURCE_ACCESS_BLUETOOTH = NO
ENABLE_RESOURCE_ACCESS_CALENDARS = YES
ENABLE_RESOURCE_ACCESS_CAMERA = NO
ENABLE_RESOURCE_ACCESS_CONTACTS = NO
ENABLE_RESOURCE_ACCESS_LOCATION = NO
ENABLE_RESOURCE_ACCESS_PRINTING = NO
ENABLE_RESOURCE_ACCESS_USB = NO
GENERATE_INFOPLIST_FILE = YES
INFOPLIST_KEY_CFBundleDisplayName = Mou Sugu
INFOPLIST_KEY_ITSAppUsesNonExemptEncryption = NO
INFOPLIST_KEY_LSApplicationCategoryType = public.app-category.productivity
INFOPLIST_KEY_LSUIElement = YES
INFOPLIST_KEY_NSAppleEventsUsageDescription = Mou Sugu asks Calendar to show the day you clicked in the month view.
INFOPLIST_KEY_NSCalendarsFullAccessUsageDescription = Mou Sugu uses your calendar to show the next event and remaining time directly in the menu bar.
LD_RUNPATH_SEARCH_PATHS = @executable_path/../Frameworks
MACOSX_DEPLOYMENT_TARGET = 15.0
MARKETING_VERSION = 1.3.4
PRODUCT_BUNDLE_IDENTIFIER = dev.1930.MouSugu
PRODUCT_NAME = MouSugu
SDKROOT = macosx
STRING_CATALOG_GENERATE_SYMBOLS = YES
SUPPORTED_PLATFORMS = macosx
SWIFT_APPROACHABLE_CONCURRENCY = YES
SWIFT_DEFAULT_ACTOR_ISOLATION = MainActor
SWIFT_EMIT_LOC_STRINGS = YES
SWIFT_UPCOMING_FEATURE_MEMBER_IMPORT_VISIBILITY = YES
SWIFT_VERSION = 5.0
