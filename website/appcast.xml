<?xml version="1.0" encoding="utf-8"?>
<!--
  Sparkle update feed for the direct/DMG channel. Published at
  https://mousugu.app/appcast.xml, which is what SUFeedURL in
  Config/Direct-Info.plist points at.

  Do not hand-edit the <item> entries: scripts/release.sh regenerates this file
  with Sparkle's generate_appcast, which signs each build with the Ed25519 key
  held in the Keychain. An empty channel is valid and simply means "no updates".
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle">
    <channel>
        <title>Mou Sugu</title>
        <link>https://mousugu.app/appcast.xml</link>
        <description>Update feed for the direct download of Mou Sugu.</description>
        <language>en</language>
    </channel>
</rss>
