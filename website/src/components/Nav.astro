---
// Nav.astro — landing navigation. On desktop: inline text links, GitHub as an
// icon, and a no-JS language dropdown. On mobile the same links collapse into a
// slide-in drawer driven by a checkbox (no JS needed to open/close); a small
// progressive enhancement closes it on link tap / Escape.

interface Props {
  lang: 'en' | 'es' | 'ja';
  labels: { features: string; faq: string; blog: string; menu: string };
  home: string;
}

const { lang, labels, home } = Astro.props;

const languages = [
  { code: 'en', name: 'English', href: '/' },
  { code: 'es', name: 'Español', href: '/es' },
  { code: 'ja', name: '日本語', href: '/ja' },
];
---

<nav class="nav" aria-label="Main">
  <a class="brand" href={home}>
    <img src="/icon.png" alt="Mou Sugu app icon" width="28" height="28" />
    Mou Sugu <span class="kana" aria-hidden="true">もうすぐ</span>
  </a>

  <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label={labels.menu} />
  <label class="nav-btn nav-open" for="nav-toggle" aria-label={labels.menu}>
    <svg viewBox="0 0 20 20" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M3 6h14M3 10h14M3 14h14" stroke-linecap="round" />
    </svg>
  </label>
  <label class="nav-backdrop" for="nav-toggle" aria-hidden="true"></label>

  <div class="links">
    <label class="nav-btn nav-close" for="nav-toggle" aria-label="Close menu">
      <svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <path d="M5 5l10 10M15 5L5 15" stroke-linecap="round" />
      </svg>
    </label>
    <a href="#features">{labels.features}</a>
    <a href="#faq">{labels.faq}</a>
    <a href="/blog">{labels.blog}</a>
    <a class="icon-link" href="https://github.com/1930-dev/mousugu" target="_blank" rel="noopener" aria-label="GitHub">
      <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
      </svg>
      <span class="icon-label">GitHub</span>
    </a>
    <details class="lang">
      <summary aria-label="Language">
        <svg viewBox="0 0 16 16" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
          <circle cx="8" cy="8" r="6.5" />
          <ellipse cx="8" cy="8" rx="3" ry="6.5" />
          <path d="M1.5 8h13M2.5 4.5h11M2.5 11.5h11" />
        </svg>
      </summary>
      <div class="lang-menu">
        {languages.map((l) => (
          <a href={l.href} lang={l.code} aria-current={l.code === lang ? 'true' : undefined}>
            {l.name}
          </a>
        ))}
      </div>
    </details>

    <!-- Flat language list for the drawer: a closed <details> hides its own
         content, so the dropdown above can't double as the mobile list. -->
    <div class="lang-drawer">
      {languages.map((l) => (
        <a href={l.href} lang={l.code} aria-current={l.code === lang ? 'true' : undefined}>
          {l.name}
        </a>
      ))}
    </div>
  </div>

  <script is:inline>
    (function () {
      var t = document.getElementById('nav-toggle');
      if (!t) return;
      var close = function () { t.checked = false; };
      // Hash links don't reload the page, so close the drawer explicitly.
      document.querySelectorAll('.nav .links a').forEach(function (a) {
        a.addEventListener('click', close);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') close();
      });
    })();
  </script>
</nav>
