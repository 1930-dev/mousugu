---
// Base.astro — the single source of on-page SEO for every page.
// Pass per-page metadata via props; JSON-LD blocks come in through `schemas`.
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Path of this page, e.g. "/" or "/es" — used for canonical + hreflang. */
  path: string;
  lang?: 'en' | 'es' | 'ja';
  /** Language alternates of this page (include the page itself). x-default → en. */
  alternates?: { lang: string; path: string }[];
  /** JSON-LD objects, serialized verbatim into script tags. */
  schemas?: object[];
}

const { title, description, path, lang = 'en', alternates = [], schemas = [] } = Astro.props;
const site = 'https://mousugu.app';
const canonical = new URL(path, site).href;
const ogImage = `${site}/og-image.png`;
const ogLocale = { en: 'en_US', es: 'es_ES', ja: 'ja_JP' }[lang];
const xDefault = alternates.find((a) => a.lang === 'en');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.lang} href={new URL(a.path, site).href} />
    ))}
    {xDefault && <link rel="alternate" hreflang="x-default" href={new URL(xDefault.path, site).href} />}
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="Mou Sugu updates" href="/appcast.xml" />
    <meta name="theme-color" content="#111113" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mou Sugu" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Mou Sugu — menu bar calendar for Mac with a live meeting countdown" />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </head>
  <body>
    <slot />
  </body>
</html>
